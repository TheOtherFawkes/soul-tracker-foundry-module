{
  "id": "soul-tracker",
  "title": "Soul Tracker (CoC Parasite Manifest)",
  "description": "GM-only passenger/infestation tracker for a Call of Cthulhu one-shot. Auto-syncs to world actors, infest from inside the tracker, live updates, editable alert presets, narrative JSON export.",
  "version": "1.4.0",
  "compatibility": {
    "minimum": "13",
    "verified": "13",
    "maximum": "13"
  },
  "authors": [
    {
      "name": "Michael"
    }
  ],
  "esmodules": [
    "scripts/soul-tracker.js"
  ],
  "styles": [
    "styles/soul-tracker.css"
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "relationships": {
    "requires": [
      {
        "id": "socketlib",
        "type": "module",
        "compatibility": {
          "minimum": "1.0.0"
        }
      }
    ],
    "recommends": [
      {
        "id": "geanos-secret-rolls",
        "type": "module",
        "reason": "Enables true secret rolls so possession and sanity dice leave no placeholder cards for players."
      }
    ]
  },
  "socket": true,
  "manifest": "https://raw.githubusercontent.com/TheOtherFawkes/soul-tracker-foundry-module/main/module.json",
  "download": "https://github.com/TheOtherFawkes/soul-tracker-foundry-module/releases/download/v1.4.0/soul-tracker.zip"
}
